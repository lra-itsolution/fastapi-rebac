DATABASE_URL=postgresql+asyncpg://rebac:rebac@localhost:5432/rebac_example
JWT_SECRET=change-me-jwt-secret
RESET_PASSWORD_SECRET=change-me-reset-secret
VERIFICATION_SECRET=change-me-verify-secret
CSRF_SECRET=change-me-csrf-secret
COOKIE_SECURE=false
SQL_ECHO=false
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_USERNAME=admin
FIRST_SUPERUSER_PASSWORD=admin12345

# Optional suspicious activity detection MVP.
# Rule-based checks work without extra dependencies.
# PyOD requires installing the project with the anomaly extra: pip install -e ".[example,anomaly]"
SUSPICIOUS_ACTIVITY_ENABLED=true
SUSPICIOUS_ACTIVITY_RULES_ENABLED=true
SUSPICIOUS_ACTIVITY_PYOD_ENABLED=true
SUSPICIOUS_ACTIVITY_WINDOW_MINUTES=60
SUSPICIOUS_ACTIVITY_PYOD_MIN_ROWS=5
SUSPICIOUS_ACTIVITY_MIN_EVENTS_FOR_PYOD=20
SUSPICIOUS_ACTIVITY_PYOD_CONTAMINATION=0.15
SUSPICIOUS_ACTIVITY_MANY_DENIED_THRESHOLD=10
SUSPICIOUS_ACTIVITY_BULK_READ_THRESHOLD=100
SUSPICIOUS_ACTIVITY_MANY_DELETES_THRESHOLD=10
SUSPICIOUS_ACTIVITY_MANY_UNIQUE_OBJECTS_THRESHOLD=50
SUSPICIOUS_ACTIVITY_MANY_UNIQUE_IPS_THRESHOLD=3
SUSPICIOUS_ACTIVITY_NIGHT_START_HOUR=22
SUSPICIOUS_ACTIVITY_NIGHT_END_HOUR=6
